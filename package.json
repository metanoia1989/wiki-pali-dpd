{
  "name": "wiki-pali-dpd",
  "version": "0.2.0",
  "description": "Tampermonkey userscript for Wiki Pali - adds declension tables and compound word deconstruction using DPD data",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "python3 -m http.server 8080 -d .",
    "export-db": "python3 scripts/export/web_db.py --src ~/WorkSpace/dpd-db/dpd.db",
    "get-db": "cp data/dpd-web.db.gz ./data/dpd-web.db.gz"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "vite": "^5.4.0 || ^6.0.0",
    "wrangler": "^4.106.0"
  }
}
